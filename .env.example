# Core cache mode
CACHE_MODE=ttl
CACHE_TTL_SECONDS=60
CACHE_CONFIG_PATH=/runtime/cache_config.json

# API service
LOG_LEVEL=INFO
REPLICA_LAG_SECONDS=0
REDIS_HOST=redis
REDIS_PORT=6379
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=appdb
MYSQL_USER=app_user
MYSQL_PASSWORD=app_password

# UI service
CACHEFRONT_API_URL=http://api:8000
CACHEFRONT_DEFAULT_USER_ID=1

# CDC consumer
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC=cachefront.appdb.users
KAFKA_GROUP_ID=cachefront-cdc-consumer
CDC_METRICS_PORT=9101

# Observability
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
